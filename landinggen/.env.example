## AI (Anthropic / Claude via Vercel AI SDK)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE
# Optional (defaults to claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

## Firebase (client-side Auth + Firestore)
NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY_HERE
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID_HERE
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID_HERE
NEXT_PUBLIC_FIREBASE_APP_ID=YOUR_APP_ID_HERE

## Leads destination (optional)
# Used by the published landing to store leads under: leads/<clientId>/entries
NEXT_PUBLIC_LEADS_CLIENT_ID=your-client-id

## Vercel publishing (server-side)
## Prefer VERCEL_AUTH_TOKEN (VERCEL_TOKEN still supported for backwards compatibility)
VERCEL_AUTH_TOKEN=YOUR_VERCEL_TOKEN_HERE
VERCEL_TOKEN=YOUR_VERCEL_TOKEN_HERE
VERCEL_TEAM_ID=team_xxxxxxxxxxxxxxxxxxxxxxxx
# Optional: target a specific project name
VERCEL_PROJECT_NAME=landing-studio-generated
# Optional: if set, publish will alias to <deploymentIdPrefix>.<rootDomain>
VERCEL_ROOT_DOMAIN=example.com

